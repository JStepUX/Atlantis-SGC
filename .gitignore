# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Atlantis outputs (regenerable artifacts)
Data/chroma/
Data/chunks/
Data/index.json
Data/index.md

# Keep raw inputs tracked? Up to you — by default we ignore bulky raw corpora.
# Comment the next line out if you want raw docs in version control.
Data/raw/*
!Data/raw/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# ── AIX layer: local-only working context ──
# Spec docs (active + archived) are local working context; convention READMEs stay.
docs/specs/*
!docs/specs/README.md
docs/ignored/*
!docs/ignored/README.md
# pre-commit-qa marker (branch- and time-scoped, regenerated each pass) + per-user overrides
.claude/state/
.claude/settings.local.json
